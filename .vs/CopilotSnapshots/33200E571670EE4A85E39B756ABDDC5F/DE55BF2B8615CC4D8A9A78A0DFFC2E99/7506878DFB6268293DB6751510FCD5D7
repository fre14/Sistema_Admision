using System.Threading.Tasks;

namespace SAA.Domain.Interfaces;

/// <summary>
/// Interface específica para operaciones del repositorio de Postulantes
/// </summary>
public interface IPostulanteRepository : IRepository<Entities.Postulante>
{
    /// <summary>
    /// Busca postulantes por número de documento
    /// </summary>
    /// <param name="numeroDocumento">Número de documento</param>
    /// <returns>El postulante encontrado o null</returns>
    Task<Entities.Postulante?> GetByNumeroDocumentoAsync(string numeroDocumento);

    /// <summary>
    /// Busca postulantes por correo electrónico
    /// </summary>
    /// <param name="correo">Correo electrónico</param>
    /// <returns>El postulante encontrado o null</returns>
    Task<Entities.Postulante?> GetByCorreoAsync(string correo);

    /// <summary>
    /// Registra un postulante usando el stored procedure Admision.SP_RegistrarPostulante
    /// </summary>
    /// <param name="postulante">Entidad postulante</param>
    /// <returns>El id generado o 0 si falla</returns>
    Task<int> RegistrarPostulanteAsync(Entities.Postulante postulante);
}

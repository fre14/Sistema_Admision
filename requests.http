@baseUrl = http://localhost:5000/api

### 1. LOGIN - Autenticarse con credenciales
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "nombreUsuario": "fredy",
  "contrasena": "123456"
}

###

### 2. REGISTRAR INGRESO - Juan Pérez García
POST {{baseUrl}}/ingreso/registrar
Content-Type: application/json
Authorization: {REEMPLAZAR_CON_TOKEN}

{
  "nombrePostulante": "Juan Pérez García",
  "observaciones": "Ingresó a las 8:30 AM"
}

###

